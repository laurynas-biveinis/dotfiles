{
  "permissions": {
    "allow": [
      "mcp__elisp-dev__elisp-describe-function",
      "mcp__elisp-dev__elisp-info-lookup-symbol",
      "Bash(find:*)",
      "Bash(ls:*)",
      "mcp__elisp-dev__elisp-describe-variable",
      "Bash(readlink:*)",
      "Bash(mkdir:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(gh repo view:*)",
      "Bash(gh auth refresh:*)",
      "Bash(checkov:*)",
      "Bash(./check.sh)",
      "Bash(zizmor:*)",
      "WebSearch",
      "Bash(prettier:*)",
      "Bash(git log:*)",
      "Bash(cat:*)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_check_sh.py",
            "if": "Bash(./check.sh *)"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/block_git_wildcard_staging.py",
            "if": "Bash(git *)"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_elisp_syntax.py",
            "if": "Write(*.el)"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_elisp_syntax.py",
            "if": "Edit(*.el)"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/validate_elisp_syntax.py",
            "if": "MultiEdit(*.el)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -j 'select(.tool_input.file_path | endswith(\".md\")) | .tool_input.file_path + \"\\u0000\"' | xargs -0 -r prettier --write",
            "if": "Write(*.md)|Edit(*.md)|MultiEdit(*.md)"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-code-wakatime@wakatime": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "model": "claude-fable-5[1m]"
}
